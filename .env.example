# NanoClaw Layer 1 Configuration
# Copy this file to .env and fill in your actual values
# Never commit .env to version control - it contains sensitive credentials

# ============================================================================
# CREDENTIAL MANAGEMENT - OneCLI Integration
# ============================================================================
# OneCLI Mode: 'synthetic' (default, for development) or 'vault' (production)
ONECLI_MODE=synthetic

# Path to OneCLI workspace (inside Docker container)
ONECLI_WORKSPACE=/workspace

# Path to OneCLI configuration directory (mounted from host)
ONECLI_CONFIG_PATH=/etc/onecli

# ============================================================================
# ANTHROPIC API - Claude Integration
# ============================================================================
# Anthropic API key for Claude models
# Generate at: https://console.anthropic.com/
# Inside Docker: uses synthetic key when ONECLI_MODE=synthetic
ANTHROPIC_API_KEY=sk-ant-your-actual-key-here

# Claude API base URL (default: https://api.anthropic.com)
CLAUDE_API_BASE=https://api.anthropic.com

# ============================================================================
# THIRD-PARTY API KEYS
# ============================================================================
# OpenAI API key (for GPT models if used)
# Generate at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-actual-key-here

# Google API key (for Google services, Maps, etc.)
# Generate at: https://console.cloud.google.com/
GOOGLE_API_KEY=AIza-your-actual-key-here

# GitHub Personal Access Token (for repository access)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your-actual-token-here

# ============================================================================
# TELEGRAM BOT INTEGRATION - Layer 2
# ============================================================================
# Telegram Bot Token (for Telegram bot connection)
# Create a bot via @BotFather on Telegram: https://t.me/BotFather
# Get the token from the setup message
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ============================================================================
# RUNTIME & LOGGING CONFIGURATION
# ============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable debug mode (verbose output)
DEBUG=false

# Node environment
NODE_ENV=development

# ============================================================================
# BROWSER & AGENT CONFIGURATION
# ============================================================================
# Chromium executable path (inside Docker container)
AGENT_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium

# Playwright chromium path
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# Skip browser download (already installed in Docker image)
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# ============================================================================
# DOCKER & CONTAINER CONFIGURATION
# ============================================================================
# Container timezone
TZ=UTC

# Container memory limit (in compose file: 2G default)
# Leave blank to use docker-compose.yml settings
MEMORY_LIMIT=2G

# ============================================================================
# DATABASE & PERSISTENCE
# ============================================================================
# SQLite database path (inside Docker container)
DATABASE_PATH=/data/nanoclaw.db

# Workspace directory (persistent volume)
WORKSPACE_PATH=/workspace

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================
# Agent name (user-friendly identifier)
AGENT_NAME=NanoClaw-Local

# Agent description
AGENT_DESCRIPTION=Local development instance of NanoClaw

# Port for agent HTTP server (if applicable)
AGENT_PORT=8080

# ============================================================================
# DEVELOPMENT & TESTING
# ============================================================================
# Enable test mode (skips certain validations)
TEST_MODE=false

# Enable dry-run mode (simulates actions without executing them)
DRY_RUN=false
